<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
        xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
        xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
        xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
        xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
        id="Definitions_board_moderation_process"
        targetNamespace="http://itmo.ru/blps/camunda">

    <bpmn:message id="Message_BoardModerationRequested" name="BoardModerationRequestedMessage"/>

    <bpmn:process id="board-moderation-process"
                  name="Board moderation process"
                  isExecutable="true"
                  camunda:historyTimeToLive="30">

        <bpmn:startEvent id="StartEvent_SubmitModeration" name="Submit moderation">
            <bpmn:outgoing>Flow_Start_To_Validate</bpmn:outgoing>
        </bpmn:startEvent>

        <bpmn:serviceTask id="ServiceTask_ValidateSubmission"
                          name="Check access and board status"
                          camunda:delegateExpression="${validateBoardModerationSubmissionDelegate}">
            <bpmn:incoming>Flow_Start_To_Validate</bpmn:incoming>
            <bpmn:outgoing>Flow_Validate_To_SetSubmitted</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:serviceTask id="ServiceTask_SetSubmitted"
                          name="Set board status SUBMITTED"
                          camunda:delegateExpression="${setBoardSubmittedDelegate}">
            <bpmn:incoming>Flow_Validate_To_SetSubmitted</bpmn:incoming>
            <bpmn:outgoing>Flow_SetSubmitted_To_CreateOutbox</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:serviceTask id="ServiceTask_CreateOutbox"
                          name="Create outbox event"
                          camunda:delegateExpression="${createBoardModerationOutboxEventDelegate}">
            <bpmn:incoming>Flow_SetSubmitted_To_CreateOutbox</bpmn:incoming>
            <bpmn:outgoing>Flow_CreateOutbox_To_WaitKafka</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:intermediateCatchEvent id="CatchEvent_WaitKafkaMessage"
                                     name="Wait Kafka moderation event">
            <bpmn:incoming>Flow_CreateOutbox_To_WaitKafka</bpmn:incoming>
            <bpmn:outgoing>Flow_WaitKafka_To_CreateRequest</bpmn:outgoing>
            <bpmn:messageEventDefinition messageRef="Message_BoardModerationRequested"/>
        </bpmn:intermediateCatchEvent>

        <bpmn:serviceTask id="ServiceTask_CreateModerationRequest"
                          name="Create moderation request"
                          camunda:delegateExpression="${createModerationRequestDelegate}">
            <bpmn:incoming>Flow_WaitKafka_To_CreateRequest</bpmn:incoming>
            <bpmn:outgoing>Flow_CreateRequest_To_CreateBitrixTask</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:serviceTask id="ServiceTask_CreateBitrixTask"
                          name="Create Bitrix24 task"
                          camunda:delegateExpression="${createBitrixModerationTaskDelegate}">
            <bpmn:incoming>Flow_CreateRequest_To_CreateBitrixTask</bpmn:incoming>
            <bpmn:outgoing>Flow_CreateBitrixTask_To_AdminTask</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:userTask id="UserTask_AdminDecision"
                       name="Admin moderation decision"
                       camunda:assignee="admin">
            <bpmn:incoming>Flow_CreateBitrixTask_To_AdminTask</bpmn:incoming>
            <bpmn:outgoing>Flow_AdminTask_To_Gateway</bpmn:outgoing>
        </bpmn:userTask>

        <bpmn:exclusiveGateway id="Gateway_ModerationDecision" name="Decision?">
            <bpmn:incoming>Flow_AdminTask_To_Gateway</bpmn:incoming>
            <bpmn:outgoing>Flow_Gateway_To_Approve</bpmn:outgoing>
            <bpmn:outgoing>Flow_Gateway_To_Reject</bpmn:outgoing>
        </bpmn:exclusiveGateway>

        <bpmn:serviceTask id="ServiceTask_ApproveBoard"
                          name="Approve board"
                          camunda:delegateExpression="${approveBoardModerationDelegate}">
            <bpmn:incoming>Flow_Gateway_To_Approve</bpmn:incoming>
            <bpmn:outgoing>Flow_Approve_To_SyncBitrix</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:serviceTask id="ServiceTask_RejectBoard"
                          name="Reject board"
                          camunda:delegateExpression="${rejectBoardModerationDelegate}">
            <bpmn:incoming>Flow_Gateway_To_Reject</bpmn:incoming>
            <bpmn:outgoing>Flow_Reject_To_SyncBitrix</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:serviceTask id="ServiceTask_SyncBitrixDecision"
                          name="Add Bitrix comment and close task"
                          camunda:delegateExpression="${syncBitrixModerationDecisionDelegate}">
            <bpmn:incoming>Flow_Approve_To_SyncBitrix</bpmn:incoming>
            <bpmn:incoming>Flow_Reject_To_SyncBitrix</bpmn:incoming>
            <bpmn:outgoing>Flow_SyncBitrix_To_End</bpmn:outgoing>
        </bpmn:serviceTask>

        <bpmn:endEvent id="EndEvent_ModerationFinished" name="Moderation finished">
            <bpmn:incoming>Flow_SyncBitrix_To_End</bpmn:incoming>
        </bpmn:endEvent>

        <bpmn:sequenceFlow id="Flow_Start_To_Validate"
                           sourceRef="StartEvent_SubmitModeration"
                           targetRef="ServiceTask_ValidateSubmission"/>

        <bpmn:sequenceFlow id="Flow_Validate_To_SetSubmitted"
                           sourceRef="ServiceTask_ValidateSubmission"
                           targetRef="ServiceTask_SetSubmitted"/>

        <bpmn:sequenceFlow id="Flow_SetSubmitted_To_CreateOutbox"
                           sourceRef="ServiceTask_SetSubmitted"
                           targetRef="ServiceTask_CreateOutbox"/>

        <bpmn:sequenceFlow id="Flow_CreateOutbox_To_WaitKafka"
                           sourceRef="ServiceTask_CreateOutbox"
                           targetRef="CatchEvent_WaitKafkaMessage"/>

        <bpmn:sequenceFlow id="Flow_WaitKafka_To_CreateRequest"
                           sourceRef="CatchEvent_WaitKafkaMessage"
                           targetRef="ServiceTask_CreateModerationRequest"/>

        <bpmn:sequenceFlow id="Flow_CreateRequest_To_CreateBitrixTask"
                           sourceRef="ServiceTask_CreateModerationRequest"
                           targetRef="ServiceTask_CreateBitrixTask"/>

        <bpmn:sequenceFlow id="Flow_CreateBitrixTask_To_AdminTask"
                           sourceRef="ServiceTask_CreateBitrixTask"
                           targetRef="UserTask_AdminDecision"/>

        <bpmn:sequenceFlow id="Flow_AdminTask_To_Gateway"
                           sourceRef="UserTask_AdminDecision"
                           targetRef="Gateway_ModerationDecision"/>

        <bpmn:sequenceFlow id="Flow_Gateway_To_Approve"
                           sourceRef="Gateway_ModerationDecision"
                           targetRef="ServiceTask_ApproveBoard">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${moderationDecision == 'APPROVED'}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <bpmn:sequenceFlow id="Flow_Gateway_To_Reject"
                           sourceRef="Gateway_ModerationDecision"
                           targetRef="ServiceTask_RejectBoard">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${moderationDecision == 'REJECTED'}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <bpmn:sequenceFlow id="Flow_Approve_To_SyncBitrix"
                           sourceRef="ServiceTask_ApproveBoard"
                           targetRef="ServiceTask_SyncBitrixDecision"/>

        <bpmn:sequenceFlow id="Flow_Reject_To_SyncBitrix"
                           sourceRef="ServiceTask_RejectBoard"
                           targetRef="ServiceTask_SyncBitrixDecision"/>

        <bpmn:sequenceFlow id="Flow_SyncBitrix_To_End"
                           sourceRef="ServiceTask_SyncBitrixDecision"
                           targetRef="EndEvent_ModerationFinished"/>

    </bpmn:process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_board_moderation_process">
        <bpmndi:BPMNPlane id="BPMNPlane_board_moderation_process" bpmnElement="board-moderation-process">

            <bpmndi:BPMNShape id="StartEvent_SubmitModeration_di" bpmnElement="StartEvent_SubmitModeration">
                <dc:Bounds x="120" y="120" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_ValidateSubmission_di" bpmnElement="ServiceTask_ValidateSubmission">
                <dc:Bounds x="210" y="98" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_SetSubmitted_di" bpmnElement="ServiceTask_SetSubmitted">
                <dc:Bounds x="430" y="98" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_CreateOutbox_di" bpmnElement="ServiceTask_CreateOutbox">
                <dc:Bounds x="650" y="98" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="CatchEvent_WaitKafkaMessage_di" bpmnElement="CatchEvent_WaitKafkaMessage">
                <dc:Bounds x="880" y="120" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_CreateModerationRequest_di" bpmnElement="ServiceTask_CreateModerationRequest">
                <dc:Bounds x="970" y="98" width="180" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_CreateBitrixTask_di" bpmnElement="ServiceTask_CreateBitrixTask">
                <dc:Bounds x="1200" y="98" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="UserTask_AdminDecision_di" bpmnElement="UserTask_AdminDecision">
                <dc:Bounds x="1420" y="98" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="Gateway_ModerationDecision_di" bpmnElement="Gateway_ModerationDecision" isMarkerVisible="true">
                <dc:Bounds x="1640" y="113" width="50" height="50"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_ApproveBoard_di" bpmnElement="ServiceTask_ApproveBoard">
                <dc:Bounds x="1760" y="40" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_RejectBoard_di" bpmnElement="ServiceTask_RejectBoard">
                <dc:Bounds x="1760" y="170" width="170" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="ServiceTask_SyncBitrixDecision_di" bpmnElement="ServiceTask_SyncBitrixDecision">
                <dc:Bounds x="2000" y="98" width="200" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="EndEvent_ModerationFinished_di" bpmnElement="EndEvent_ModerationFinished">
                <dc:Bounds x="2280" y="120" width="36" height="36"/>
            </bpmndi:BPMNShape>

        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</bpmn:definitions>