<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_board_delete_process" targetNamespace="http://itmo.ru/blps/camunda">
  <bpmn:process id="board-delete-process" name="Board delete process" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_DeleteBoard" name="Delete board requested" camunda:initiator="processStarter">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="boardId" label="Board ID" type="long" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_Confirm</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_ConfirmBoardDeletion" name="Confirm board deletion" camunda:assignee="${processStarter}">
      <bpmn:incoming>Flow_Start_To_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_To_DeleteBoard</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_DeleteBoard" name="Check access and delete board" camunda:delegateExpression="${deleteBoardDelegate}">
      <bpmn:incoming>Flow_Confirm_To_DeleteBoard</bpmn:incoming>
      <bpmn:outgoing>Flow_DeleteBoard_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_BoardDeleted" name="Board deleted">
      <bpmn:incoming>Flow_DeleteBoard_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Confirm" sourceRef="StartEvent_DeleteBoard" targetRef="UserTask_ConfirmBoardDeletion" />
    <bpmn:sequenceFlow id="Flow_Confirm_To_DeleteBoard" sourceRef="UserTask_ConfirmBoardDeletion" targetRef="ServiceTask_DeleteBoard" />
    <bpmn:sequenceFlow id="Flow_DeleteBoard_To_End" sourceRef="ServiceTask_DeleteBoard" targetRef="EndEvent_BoardDeleted" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_board_delete_process">
    <bpmndi:BPMNPlane id="BPMNPlane_board_delete_process" bpmnElement="board-delete-process">
      <bpmndi:BPMNShape id="StartEvent_DeleteBoard_di" bpmnElement="StartEvent_DeleteBoard">
        <dc:Bounds x="140" y="130" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_ConfirmBoardDeletion_di" bpmnElement="UserTask_ConfirmBoardDeletion">
        <dc:Bounds x="350" y="130" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_DeleteBoard_di" bpmnElement="ServiceTask_DeleteBoard">
        <dc:Bounds x="560" y="130" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_BoardDeleted_di" bpmnElement="EndEvent_BoardDeleted">
        <dc:Bounds x="770" y="130" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_To_Confirm_di" bpmnElement="Flow_Start_To_Confirm">
        <di:waypoint x="176" y="148" />
        <di:waypoint x="263" y="148" />
        <di:waypoint x="263" y="170" />
        <di:waypoint x="350" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Confirm_To_DeleteBoard_di" bpmnElement="Flow_Confirm_To_DeleteBoard">
        <di:waypoint x="500" y="170" />
        <di:waypoint x="560" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DeleteBoard_To_End_di" bpmnElement="Flow_DeleteBoard_To_End">
        <di:waypoint x="710" y="170" />
        <di:waypoint x="740" y="170" />
        <di:waypoint x="740" y="148" />
        <di:waypoint x="770" y="148" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>