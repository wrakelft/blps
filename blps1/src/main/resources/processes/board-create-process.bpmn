<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_board_create_process" targetNamespace="http://itmo.ru/blps/camunda">
  <bpmn:process id="board-create-process" name="Board create process" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_CreateBoard" name="Create board requested" camunda:initiator="processStarter">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="boardName" label="Board name" type="string" />
          <camunda:formField id="boardDescription" label="Board description" type="string" />
          <camunda:formField id="boardPrivacy" label="Board privacy" type="enum" defaultValue="PUBLIC">
            <camunda:value id="PUBLIC" name="Public" />
            <camunda:value id="PRIVATE" name="Private" />
          </camunda:formField>
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_Confirm</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_ConfirmBoardCreation" name="Confirm board creation" camunda:assignee="${processStarter}">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="boardName" label="Board name" type="string" defaultValue="${boardName}" />
          <camunda:formField id="boardDescription" label="Board description" type="string" defaultValue="${boardDescription}" />
          <camunda:formField id="boardPrivacy" label="Board privacy" type="string" defaultValue="${boardPrivacy}" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirm_To_Create</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ServiceTask_CreateBoard" name="Create board in application" camunda:delegateExpression="${createBoardDelegate}">
      <bpmn:incoming>Flow_Confirm_To_Create</bpmn:incoming>
      <bpmn:outgoing>Flow_Create_To_ShowResult</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="UserTask_ShowCreatedBoardResult" name="Show created board result" camunda:assignee="${processStarter}">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="createdBoardId" label="Created board ID" type="long" defaultValue="${createdBoardId}" />
          <camunda:formField id="createdBoardName" label="Created board name" type="string" defaultValue="${createdBoardName}" />
          <camunda:formField id="createdBoardPrivacy" label="Created board privacy" type="string" defaultValue="${createdBoardPrivacy}" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Create_To_ShowResult</bpmn:incoming>
      <bpmn:outgoing>Flow_ShowResult_To_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_BoardCreated" name="Board created">
      <bpmn:incoming>Flow_ShowResult_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Confirm" sourceRef="StartEvent_CreateBoard" targetRef="UserTask_ConfirmBoardCreation" />
    <bpmn:sequenceFlow id="Flow_Confirm_To_Create" sourceRef="UserTask_ConfirmBoardCreation" targetRef="ServiceTask_CreateBoard" />
    <bpmn:sequenceFlow id="Flow_Create_To_ShowResult" sourceRef="ServiceTask_CreateBoard" targetRef="UserTask_ShowCreatedBoardResult" />
    <bpmn:sequenceFlow id="Flow_ShowResult_To_End" sourceRef="UserTask_ShowCreatedBoardResult" targetRef="EndEvent_BoardCreated" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_board_create_process">
    <bpmndi:BPMNPlane id="BPMNPlane_board_create_process" bpmnElement="board-create-process">
      <bpmndi:BPMNShape id="StartEvent_CreateBoard_di" bpmnElement="StartEvent_CreateBoard">
        <dc:Bounds x="140" y="130" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_ConfirmBoardCreation_di" bpmnElement="UserTask_ConfirmBoardCreation">
        <dc:Bounds x="350" y="130" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_CreateBoard_di" bpmnElement="ServiceTask_CreateBoard">
        <dc:Bounds x="560" y="130" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_ShowCreatedBoardResult_di" bpmnElement="UserTask_ShowCreatedBoardResult">
        <dc:Bounds x="770" y="130" width="150" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_BoardCreated_di" bpmnElement="EndEvent_BoardCreated">
        <dc:Bounds x="980" y="130" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_To_Confirm_di" bpmnElement="Flow_Start_To_Confirm">
        <di:waypoint x="176" y="148" />
        <di:waypoint x="263" y="148" />
        <di:waypoint x="263" y="170" />
        <di:waypoint x="350" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Confirm_To_Create_di" bpmnElement="Flow_Confirm_To_Create">
        <di:waypoint x="500" y="170" />
        <di:waypoint x="560" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Create_To_ShowResult_di" bpmnElement="Flow_Create_To_ShowResult">
        <di:waypoint x="710" y="170" />
        <di:waypoint x="770" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ShowResult_To_End_di" bpmnElement="Flow_ShowResult_To_End">
        <di:waypoint x="920" y="170" />
        <di:waypoint x="950" y="170" />
        <di:waypoint x="950" y="148" />
        <di:waypoint x="980" y="148" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>